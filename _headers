# Cloudflare Pages response headers for the marketing site. Adds the security
# headers the portal already sends. CSP is now ENFORCED (report-only rollout
# validated clean). The static site has no inline scripts; the ONLY cross-origin
# interactions are the signed-in account menu talking to the portal, so
# connect-src (session-status fetch) and form-action (sign-out POST) allow
# https://portal.bugit.dev and nothing else. ACAO is tightened from the CF
# default "*" to the site origin — public marketing content needs no sharing.
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Access-Control-Allow-Origin: https://bugit.dev
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.googletagmanager.com https://www.google.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://td.doubleclick.net https://www.google-analytics.com https://region1.google-analytics.com; font-src 'self'; media-src 'self'; connect-src 'self' https://portal.bugit.dev https://cloudflareinsights.com https://www.googletagmanager.com https://www.google.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://td.doubleclick.net https://www.google-analytics.com https://region1.google-analytics.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://portal.bugit.dev; upgrade-insecure-requests

# Content-hashed assets: referenced from HTML as /app.js?v=<hash> and
# /styles.css?v=<hash>, so a changed file always gets a NEW url (fresh fetch)
# while the HTML itself is always revalidated (max-age=0). That makes the files
# themselves safe to cache immutably for a year — eliminating the every-4h
# revalidation returning visitors used to pay. (Cloudflare matches on path, so
# this covers the ?v= query variants.)
/app.js
  Cache-Control: public, max-age=31536000, immutable
/consent.js
  Cache-Control: public, max-age=31536000, immutable
/styles.css
  Cache-Control: public, max-age=31536000, immutable

# Static media + brand assets change rarely and are not render-blocking — cache
# them for a week instead of the 4h default to cut repeat-visit bandwidth.
/public/media/*
  Cache-Control: public, max-age=604800
/public/brand/*
  Cache-Control: public, max-age=604800

# Current web guides must revalidate after every release so version switches are
# atomic across the website, portal, and update service.
/public/docs/*
  Content-Disposition: inline
  Cache-Control: public, max-age=0, must-revalidate

# Published PDFs are immutable and can remain cached for a week.
/public/docs/*.pdf
  Cache-Control: public, max-age=604800
