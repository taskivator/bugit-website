# Cloudflare Pages response headers for the marketing site. Adds the security
# headers the portal already sends. CSP is now ENFORCED (report-only rollout
# validated clean). The static site has no inline scripts; the ONLY cross-origin
# interactions are the signed-in account menu talking to the portal, so
# connect-src (session-status fetch) and form-action (sign-out POST) allow
# https://portal.bugit.dev and nothing else. ACAO is tightened from the CF
# default "*" to the site origin — public marketing content needs no sharing.
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Access-Control-Allow-Origin: https://bugit.dev
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self'; connect-src 'self' https://portal.bugit.dev https://cloudflareinsights.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://portal.bugit.dev; upgrade-insecure-requests

# Documentation PDFs: force INLINE rendering so "Preview" opens the browser's
# native PDF viewer instead of downloading. The exact same file is downloaded by
# the "Download" action (via the same-origin download attribute), so preview and
# download are byte-identical. nosniff (from /*) keeps the MIME type honest.
/public/docs/*
  Content-Disposition: inline
