# Google Ads CSP hosts, 2026-07-20. Verified against a live browser with consent
# GRANTED (denied consent redacts pings and under-reports the host set), then
# cross-checked against Google's official guide:
#   https://developers.google.com/tag-platform/security/guides/csp
#
#   script-src  + googleads.g.doubleclick.net -- gtag INJECTS the view-through
#     conversion / remarketing script from here. This site has no nonce and no
#     'strict-dynamic', so the host must be named; the portal does not need this
#     because 'strict-dynamic' already trusts what its nonce'd scripts load.
#   connect/img + ad.doubleclick.net  -- Consent Mode /ccm/s/collect endpoint.
#   connect/img + www.google.co.jp    -- the first-party user-list pixel is served
#     from the visitor's LOCAL Google ccTLD, not google.com. This account is
#     Japan-based (JPY, Asia/Tokyo). CSP cannot express a TLD wildcard, so each
#     ccTLD must be named; targeting another country will need its ccTLD, which
#     shows up as a fresh img-src violation.
#   connect/img + google.com (apex)   -- from Google's guide, not the capture: no
#     purchase conversion has fired in production yet, so the conversion path was
#     never exercised, and a blocked conversion would waste a real charge.
#
# NOT added: frame-src (Google lists googletagmanager there, but no frame request
# was ever observed and frame-src stays at the default-src 'self' fallback).
# Do not prune this list by inspection -- verify against a live page.

# Cloudflare Pages response headers for the marketing site. Adds the security
# headers the portal already sends. CSP is now ENFORCED (report-only rollout
# validated clean). The static site has no inline scripts; the ONLY cross-origin
# interactions are the signed-in account menu talking to the portal, so
# connect-src (session-status fetch) and form-action (sign-out POST) allow
# https://portal.bugit.dev and nothing else. ACAO is tightened from the CF
# default "*" to the site origin — public marketing content needs no sharing.
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Access-Control-Allow-Origin: https://bugit.dev
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.googletagmanager.com https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.googletagmanager.com https://www.google.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://td.doubleclick.net https://ad.doubleclick.net https://pagead2.googlesyndication.com https://google.com https://www.google.co.jp https://www.google-analytics.com https://region1.google-analytics.com; font-src 'self'; media-src 'self'; connect-src 'self' https://portal.bugit.dev https://www.googletagmanager.com https://www.google.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://td.doubleclick.net https://ad.doubleclick.net https://pagead2.googlesyndication.com https://google.com https://www.google.co.jp https://www.google-analytics.com https://region1.google-analytics.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://portal.bugit.dev; upgrade-insecure-requests

# Content-hashed assets: the HASH IS IN THE FILENAME (/app.<hash>.js), so a
# changed file is a genuinely new path while the HTML itself is always
# revalidated (max-age=0). That is what makes `immutable` for a year safe.
#
# It was NOT safe before. These rules used to match the bare /app.js path while
# the hash lived in a ?v= query, and Cloudflare matches _headers on path — so
# every query variant inherited a one-year immutable TTL on one never-changing
# path. On 2026-07-20 a deploy raced propagation, the edge cached the OLD body
# against the NEW ?v= key and served it as immutable, shipping new CSS with old
# JS and no way to evict it. Keep the hash in the filename.
/app.*.js
  Cache-Control: public, max-age=31536000, immutable
/consent.*.js
  Cache-Control: public, max-age=31536000, immutable
/styles.*.css
  Cache-Control: public, max-age=31536000, immutable

# Static media + brand assets change rarely and are not render-blocking — cache
# them for a week instead of the 4h default to cut repeat-visit bandwidth.
/public/media/*
  Cache-Control: public, max-age=604800
/public/brand/*
  Cache-Control: public, max-age=604800

# Current web guides must revalidate after every release so version switches are
# atomic across the website, portal, and update service.
/public/docs/*
  Content-Disposition: inline
  Cache-Control: public, max-age=0, must-revalidate

# Published PDFs are immutable and can remain cached for a week.
/public/docs/*.pdf
  Cache-Control: public, max-age=604800
