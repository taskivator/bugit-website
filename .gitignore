# BugIt marketing site — .gitignore (added 2026-07-06 for commercial launch)
# This is the PUBLIC-facing repo candidate. It must contain no secrets, no
# build output, and no local tooling state.

# Dependencies
node_modules/
.pnp
.pnp.*

# Build output (generated by build.js)
dist/
out/
build/

# Secrets / env (a public site should never carry any of these)
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
*.crt

# Logs / temp
*.log
npm-debug.log*
*.tmp

# Local dev-tool state
.claude/
.wrangler/
.vercel/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.vscode/
*.swp
